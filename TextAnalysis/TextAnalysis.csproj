<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <ProjectGuid>9EE2A913-64C2-4410-A301-939F377900E8</ProjectGuid>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>disable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <LangVersion>latest</LangVersion>
        <OutputType>Library</OutputType>
        <IsTrimmable>true</IsTrimmable>
        <IsAotCompatible>true</IsAotCompatible>
        <EnableTrimAnalyzer>true</EnableTrimAnalyzer>
        <EnableSingleFileAnalyzer>true</EnableSingleFileAnalyzer>
        <EnableAotAnalyzer>true</EnableAotAnalyzer>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
        <RuntimeIdentifiers>win-x64;linux-x64</RuntimeIdentifiers>
    </PropertyGroup>

    <PropertyGroup>
        <PackageVersion>0.1.6</PackageVersion>
        <Title>Darcara.TextAnalysis</Title>
        <PackageId>Darcara.TextAnalysis</PackageId>
        <Authors>Darcara</Authors>
        <Copyright>Copyright (c) Darcara</Copyright>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <PackageLicenseFile>LICENSE</PackageLicenseFile>
        <Description>TextAnalysis, sentence spliting, named entity recognition, translation and more</Description>
        <PackageProjectUrl>https://github.com/Darcara/TextAnalysis</PackageProjectUrl>
        <RepositoryUrl>https://github.com/Darcara/TextAnalysis</RepositoryUrl>
        <IncludeSymbols>true</IncludeSymbols>
        <SymbolPackageFormat>snupkg</SymbolPackageFormat>
        <EmbedAllSources>true</EmbedAllSources>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
        <PublishDocumentationFile>true</PublishDocumentationFile>
        <PublishRepositoryUrl>true</PublishRepositoryUrl>
        <DebugType>portable</DebugType>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="IsoEnums" Version="2026.2.1"/>
        <PackageReference Include="Microsoft.ML.OnnxRuntime.Managed" Version="1.27.0" />
        <PackageReference Include="Neco.Common" Version="0.2.4" />
        <PackageReference Include="Panlingo.LanguageIdentification.FastText" Version="0.8.0" PrivateAssets="contentfiles;analyzers;build;compile" />
        <PackageReference Include="Panlingo.LanguageIdentification.Lingua" Version="0.8.0" PrivateAssets="contentfiles;analyzers;build;compile" />
        <PackageReference Include="protobuf-net" Version="3.2.56" PrivateAssets="all"/>
        <PackageReference Include="SentencePieceTokenizer" Version="0.1.6" />
        <PackageReference Include="System.Numerics.Tensors" Version="10.0.9" />
        <PackageReference Include="Meziantou.Analyzer" Version="3.0.104" PrivateAssets="All" />
        <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="5.3.0" PrivateAssets="All" />
        <PackageReference Include="Microsoft.CodeAnalysis.NetAnalyzers" Version="10.0.301" PrivateAssets="All" />
        <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="10.0.9" />
        <PackageReference Include="Roslynator.Analyzers" Version="4.15.0" PrivateAssets="All"/>
        <PackageReference Include="Roslynator.CodeFixes" Version="4.15.0" PrivateAssets="All"/>
        <PackageReference Include="SonarAnalyzer.CSharp" Version="10.27.0.140913" PrivateAssets="All" />
    </ItemGroup>

    <ItemGroup>
        <Using Include="System"/>
        <Using Include="System.Collections.Generic"/>
        <Using Include="System.IO"/>
        <Using Include="System.Linq"/>

        <None Include="..\LICENSE" Pack="true" Link="Solution Files\LICENSE" PackagePath="."/>
        <None Include="..\README.md" Pack="true" Link="Solution Files\README.md" PackagePath="README.md"/>
        <None Include="..\.gitignore" Pack="false" Link="Solution Files\.gitignore"/>

        <InternalsVisibleTo Include="TextAnalysis.Test"/>
        <InternalsVisibleTo Include="TextAnalysis.Benchmark"/>
    </ItemGroup>

</Project>
