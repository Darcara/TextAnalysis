<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <ProjectGuid>9EE2A913-64C2-4410-A301-939F377900E8</ProjectGuid>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>disable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <LangVersion>latest</LangVersion>
        <OutputType>Library</OutputType>
        <IsTrimmable>true</IsTrimmable>
        <IsAotCompatible>true</IsAotCompatible>
        <EnableTrimAnalyzer>true</EnableTrimAnalyzer>
        <EnableSingleFileAnalyzer>true</EnableSingleFileAnalyzer>
        <EnableAotAnalyzer>true</EnableAotAnalyzer>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
        <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    </PropertyGroup>

    <PropertyGroup>
        <PackageVersion>0.1.4</PackageVersion>
        <Title>Darcara.TextAnalysis</Title>
        <PackageId>Darcara.TextAnalysis</PackageId>
        <Authors>Darcara</Authors>
        <Copyright>Copyright (c) Darcara</Copyright>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <PackageLicenseFile>LICENSE</PackageLicenseFile>
        <Description>TextAnalysis, sentence spliting, named entity recognition, translation and more</Description>
        <PackageProjectUrl>https://github.com/Darcara/TextAnalysis</PackageProjectUrl>
        <RepositoryUrl>https://github.com/Darcara/TextAnalysis</RepositoryUrl>
        <IncludeSymbols>true</IncludeSymbols>
        <SymbolPackageFormat>snupkg</SymbolPackageFormat>
        <EmbedAllSources>true</EmbedAllSources>
        <DebugType>portable</DebugType>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="IsoEnums" Version="2026.2.1"/>
        <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="10.0.3" />
        <PackageReference Include="Microsoft.ML.OnnxRuntime.Managed" Version="1.24.1"/>
        <PackageReference Include="Neco.Common" Version="0.2.2" />
        <PackageReference Include="Panlingo.LanguageIdentification.FastText" Version="0.7.2" PrivateAssets="contentfiles;analyzers;build;compile"/>
        <PackageReference Include="Panlingo.LanguageIdentification.Lingua" Version="0.7.2" PrivateAssets="contentfiles;analyzers;build;compile"/>
        <PackageReference Include="protobuf-net" Version="3.2.56" PrivateAssets="all"/>
        <PackageReference Include="SentencePieceTokenizer" Version="0.1.4"/>
        <PackageReference Include="System.Numerics.Tensors" Version="10.0.3" />
    </ItemGroup>

    <ItemGroup>
        <Using Include="System"/>
        <Using Include="System.Collections.Generic"/>
        <Using Include="System.IO"/>
        <Using Include="System.Linq"/>

        <None Include="..\LICENSE" Pack="true" Link="Solution Files\LICENSE" PackagePath="."/>
        <None Include="..\README.md" Pack="true" Link="Solution Files\README.md" PackagePath="README.md"/>
        <None Include="..\.gitignore" Pack="false" Link="Solution Files\.gitignore"/>

        <InternalsVisibleTo Include="TextAnalysis.Test"/>
        <InternalsVisibleTo Include="TextAnalysis.Benchmark"/>
    </ItemGroup>

</Project>
